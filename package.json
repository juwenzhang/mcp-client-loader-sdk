{
  "name": "mcp-client-loader-sdk",
  "version": "1.0.0",
  "description": "MCP Client Loader SDK for Node.js",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup",
    "dev": "tsx test/example.test.ts",
    "start": "node dist/index.js",
    "test:esm": "node examples/esm-test.js",
    "test:cjs": "node examples/cjs-test.cjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky install"
  },
  "keywords": [
    "mcp",
    "sdk",
    "client",
    "loader"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "dotenv": "^16.3.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "biome": "0.3.3",
    "husky": "9.1.7",
    "miniprogram-api-typings": "^5.1.3",
    "tsup": "8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
